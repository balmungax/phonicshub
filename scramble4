<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Word Wizard 🧙‍♂️</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fredoka+One&display=swap" rel="stylesheet">
<style>
:root {
  --sky: #cce8ff;
  --sun: #ffce47;      --sun-dark: #e8a800;
  --grass: #4ec76a;    --grass-dark: #2f9e4f;
  --blue: #3d8fe0;     --blue-dark: #1e66b5;
  --purple: #8b5cf6;   --purple-dark: #6d35d9;
  --coral: #f85555;    --coral-dark: #c42020;
  --ink: #172032;
  --card-radius: 26px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { height: 100%; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--sky);
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12px;
  overflow-x: hidden;
}

/* soft background blobs */
body::before {
  content: '';
  position: fixed; inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 10%, rgba(139,92,246,.13), transparent),
    radial-gradient(ellipse 50% 40% at 10% 90%, rgba(255,206,71,.18), transparent),
    radial-gradient(ellipse 40% 40% at 50% 50%, rgba(61,143,224,.08), transparent);
  pointer-events: none; z-index: 0;
}

/* ── SCREENS ── */
.screen {
  position: fixed; inset: 0;
  display: flex; justify-content: center; align-items: center;
  padding: 12px; z-index: 1; overflow-y: auto;
  transition: opacity .38s ease, transform .38s ease;
}
.screen.out-left  { opacity: 0; transform: translateX(-56px) scale(.97); pointer-events: none; }
.screen.out-right { opacity: 0; transform: translateX( 56px) scale(.97); pointer-events: none; }
.screen.hidden    { display: none; }
#screen-game { align-items: flex-start; }

/* ════════════════════════════
   HOME SCREEN
════════════════════════════ */
.home-card {
  background: white;
  border-radius: var(--card-radius);
  width: 100%; max-width: 480px;
  box-shadow: 0 10px 0 rgba(0,0,0,.1), 0 20px 50px rgba(0,0,0,.1);
  overflow: hidden;
}

.home-hero {
  background: linear-gradient(140deg, #3d8fe0 0%, #8b5cf6 100%);
  padding: 36px 28px 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
/* subtle cloud shapes in hero */
.home-hero::before {
  content: '';
  position: absolute; bottom: -20px; left: -20px; right: -20px;
  height: 50px;
  background: white;
  border-radius: 50% 50% 0 0 / 30px;
}

.wiz {
  font-size: 4.2rem;
  display: block;
  margin-bottom: 8px;
  animation: wizFloat 3.2s ease-in-out infinite;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,.2));
}
@keyframes wizFloat {
  0%,100% { transform: translateY(0) rotate(-4deg) scale(1); }
  50%      { transform: translateY(-12px) rotate(4deg) scale(1.04); }
}

.home-hero h1 {
  font-family: 'Fredoka One', cursive;
  font-size: 2.6rem;
  color: white;
  letter-spacing: 1px;
  text-shadow: 0 3px 10px rgba(0,0,0,.2);
}

.home-body { padding: 32px 24px 24px; }

.field-label {
  display: block;
  font-weight: 800; color: #476d8a;
  font-size: .75rem; text-transform: uppercase; letter-spacing: 1px;
  margin-bottom: 8px;
}

.name-row { display: flex; gap: 10px; margin-bottom: 26px; }

.name-input {
  font-family: 'Fredoka One', cursive;
  flex: 1; border: 3px solid #cce2f8; border-radius: 50px;
  padding: 11px 20px; font-size: 1.2rem; color: var(--ink);
  outline: none; letter-spacing: 1px;
  transition: border-color .2s, box-shadow .2s;
  background: #f7fbff;
}
.name-input:focus { border-color: var(--blue); box-shadow: 0 0 0 4px rgba(61,143,224,.15); }

.play-btn {
  font-family: 'Fredoka One', cursive;
  background: var(--grass); color: white; border: none;
  padding: 11px 24px; border-radius: 50px; font-size: 1.1rem;
  cursor: pointer; white-space: nowrap;
  box-shadow: 0 5px 0 var(--grass-dark);
  transition: transform .08s, box-shadow .08s;
}
.play-btn:hover  { background: #41ba5e; }
.play-btn:active { transform: translateY(4px); box-shadow: 0 1px 0 var(--grass-dark); }

/* leaderboard */
.lb-head {
  font-family: 'Fredoka One', cursive;
  font-size: 1.05rem; color: var(--ink);
  display: flex; align-items: center; gap: 6px;
  margin-bottom: 10px;
}

.lb-table { width: 100%; border-collapse: collapse; font-size: .9rem; }
.lb-table th {
  background: #f0f8ff; padding: 7px 12px;
  text-align: left; font-weight: 800; color: #3a6080;
  font-size: .7rem; text-transform: uppercase; letter-spacing: .6px;
}
.lb-table th:last-child, .lb-table td:last-child { text-align: right; }
.lb-table td { padding: 9px 12px; border-bottom: 1px solid #eaf3fc; color: var(--ink); font-weight: 700; }
.lb-table tr:last-child td { border-bottom: none; }
.lb-table tr.me td { background: #fffbea; color: #6e4800; }
.lb-empty { text-align: center; padding: 18px; color: #aabbcc; font-size: .85rem; font-weight: 700; }

.clear-link { margin-top: 12px; text-align: right; }
.clear-link button {
  background: none; border: none;
  color: #b0bec5; font-family: 'Nunito', sans-serif;
  font-size: .75rem; font-weight: 700;
  cursor: pointer; text-decoration: underline;
  transition: color .15s;
}
.clear-link button:hover { color: var(--coral); }

/* ════════════════════════════
   GAME SCREEN
════════════════════════════ */
.game-wrap {
  max-width: 680px; width: 100%;
  display: flex; flex-direction: column; gap: 12px;
  padding: 8px 0 24px;
}

/* top bar */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  background: white; border-radius: 18px;
  padding: 10px 18px;
  box-shadow: 0 4px 0 rgba(0,0,0,.08);
  gap: 10px; flex-wrap: wrap;
}
.topbar-player {
  font-family: 'Fredoka One', cursive;
  font-size: 1.05rem; color: var(--ink);
  display: flex; align-items: center; gap: 6px;
}
.topbar-score {
  background: var(--sun); border-radius: 50px;
  padding: 5px 16px; font-weight: 800; font-size: .88rem;
  color: #5c3d00; box-shadow: 0 3px 0 var(--sun-dark);
  display: flex; align-items: center; gap: 4px;
}
.home-btn {
  font-family: 'Nunito', sans-serif;
  background: #eef6ff; border: 2px solid #c0d8f0;
  color: #4a6f8a; padding: 5px 14px;
  border-radius: 50px; font-size: .8rem; font-weight: 800;
  cursor: pointer; transition: all .15s;
}
.home-btn:hover { background: #d8eeff; border-color: #99c4e8; }

/* level pips */
.level-strip { display: flex; gap: 8px; justify-content: center; align-items: center; }
.pip {
  flex: 1; height: 12px; border-radius: 10px; max-width: 110px;
  background: #d4e9f8; border: 2px solid #b0d0ea;
  transition: background .4s, border-color .4s, transform .3s;
  position: relative; overflow: hidden;
}
.pip::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.35), transparent);
  transform: translateX(-100%);
}
.pip.active {
  background: var(--sun); border-color: var(--sun-dark);
  transform: scaleY(1.4);
  box-shadow: 0 0 8px rgba(255,200,0,.4);
}
.pip.active::after { animation: shimmer 1.5s infinite; }
.pip.done { background: var(--grass); border-color: var(--grass-dark); }
@keyframes shimmer { to { transform: translateX(200%); } }

/* pip labels */
.pip-labels {
  display: flex; gap: 8px; justify-content: center;
  margin-top: -4px;
}
.pip-lbl {
  flex: 1; max-width: 110px;
  text-align: center; font-size: .62rem; font-weight: 800;
  color: #7a9db5; letter-spacing: .3px;
  transition: color .3s;
}
.pip-lbl.active { color: var(--ink); }
.pip-lbl.done   { color: var(--grass-dark); }

/* timer bar */
.timer-wrap {
  background: #e4f0fb; border-radius: 12px;
  overflow: hidden; border: 2px solid #c0d8f0;
  height: 16px; position: relative;
}
.timer-bar {
  height: 100%; border-radius: 10px;
  background: var(--grass);
  transition: width 1s linear, background .4s;
}
.timer-bar.warn   { background: var(--sun); }
.timer-bar.danger { background: var(--coral); animation: timerPulse .5s infinite alternate; }
@keyframes timerPulse { to { opacity: .7; } }
.timer-secs {
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
  font-size: .7rem; font-weight: 800; color: white;
  text-shadow: 0 1px 3px rgba(0,0,0,.3);
}

/* ── WORD CARD ── */
.word-card {
  background: white;
  border-radius: var(--card-radius);
  box-shadow: 0 8px 0 rgba(0,0,0,.1), 0 14px 30px rgba(0,0,0,.07);
  padding: 28px 22px 26px;
  text-align: center;
  position: relative; overflow: hidden;
}
.rainbow-bar {
  position: absolute; top: 0; left: 0; right: 0; height: 7px;
  background: linear-gradient(90deg, #4ec76a, #3d8fe0, #8b5cf6, #f85555, #ffce47);
  border-radius: var(--card-radius) var(--card-radius) 0 0;
}

.level-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 5px 16px; border-radius: 20px;
  font-size: .78rem; font-weight: 800;
  margin-bottom: 16px; letter-spacing: .4px;
}
.l1 { background: #d6f5e3; color: #1a5e33; }
.l2 { background: #fff3c4; color: #7a4a00; }
.l3 { background: #ffd6d6; color: #7a1818; }
.l4 { background: #ede0ff; color: #4a1880; }
.l5 { background: #ffd6ea; color: #80183a; }

/* progress dots */
.dots { display: flex; justify-content: center; gap: 7px; flex-wrap: wrap; margin-bottom: 18px; }
.dot {
  width: 14px; height: 14px; border-radius: 50%;
  background: #d4e8f8; border: 2px solid #a8cce8;
  transition: all .3s;
}
.dot.done { background: var(--grass); border-color: var(--grass-dark); }
.dot.cur  { background: var(--sun); border-color: var(--sun-dark); transform: scale(1.45); box-shadow: 0 0 6px rgba(255,200,0,.4); }

/* scrambled word */
.scrambled {
  font-family: 'Fredoka One', cursive;
  font-size: 3.8rem; letter-spacing: 10px;
  color: var(--blue-dark); line-height: 1.15;
  word-break: break-all;
  text-shadow: 2px 2px 0 rgba(61,143,224,.12);
  margin-bottom: 4px;
}
.hint {
  font-size: .78rem; color: #9ab5cc; font-weight: 700;
  margin-bottom: 20px; letter-spacing: .3px;
}

/* answer field */
.answer-input {
  font-family: 'Fredoka One', cursive;
  display: block; margin: 0 auto 16px;
  width: 100%; max-width: 300px;
  padding: 12px 22px; font-size: 1.85rem;
  text-align: center; letter-spacing: 2px;
  border: 4px solid #c4dcf5; border-radius: 60px;
  outline: none; color: var(--ink);
  background: #f8fbff;
  transition: border-color .2s, box-shadow .2s;
}
.answer-input:focus   { border-color: var(--blue); box-shadow: 0 0 0 5px rgba(61,143,224,.14); }
.answer-input:disabled { background: #f0f0f0; border-color: #ddd; color: #aaa; }
.answer-input.shake   { animation: shake .38s; }
.answer-input.glow    { animation: aglow .42s; }

@keyframes shake {
  0%,100% { transform: translateX(0); }
  20%,60% { transform: translateX(-9px); }
  40%,80% { transform: translateX(9px); }
}
@keyframes aglow {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.055); border-color: var(--grass); box-shadow: 0 0 0 6px rgba(78,199,106,.22); }
  100% { transform: scale(1); }
}

/* check button */
.check-btn {
  font-family: 'Fredoka One', cursive;
  background: var(--blue); color: white; border: none;
  font-size: 1.3rem; padding: 13px 52px;
  border-radius: 50px; cursor: pointer;
  box-shadow: 0 6px 0 var(--blue-dark);
  transition: transform .08s, box-shadow .08s, background .15s;
  letter-spacing: .5px;
}
.check-btn:hover  { background: #2f7dd0; }
.check-btn:active { transform: translateY(5px); box-shadow: 0 1px 0 var(--blue-dark); }
.check-btn:disabled { opacity: .38; pointer-events: none; }

.status-msg {
  margin-top: 14px; min-height: 28px;
  font-size: 1.05rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  color: var(--grass-dark);
}

/* ── VIRTUAL KEYBOARD ── */
.vkb {
  background: white;
  border-radius: var(--card-radius);
  padding: 14px 12px 12px;
  box-shadow: 0 6px 0 rgba(0,0,0,.1), 0 10px 24px rgba(0,0,0,.07);
  user-select: none;
}
.vkb-row {
  display: flex; justify-content: center;
  gap: 6px; margin-bottom: 6px;
}
.vkb-row:last-child { margin-bottom: 0; }

.vk {
  font-family: 'Fredoka One', cursive;
  min-width: 44px; height: 52px; padding: 0 4px;
  background: #f0f8ff; border: 2px solid #c0d8f0; border-radius: 12px;
  font-size: 1.1rem; color: var(--ink);
  cursor: pointer;
  box-shadow: 0 4px 0 #a0c4e0;
  transition: transform .07s, box-shadow .07s;
  display: flex; align-items: center; justify-content: center;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}
.vk:hover  { background: #e2f2ff; }
.vk.pressed,
.vk:active { transform: translateY(4px); box-shadow: 0 0 0 #a0c4e0; background: #d4eaff; }

.vk.del {
  background: #fff0f0; border-color: #f5b8b8;
  color: var(--coral-dark);
  box-shadow: 0 4px 0 #e89090;
  min-width: 64px; font-size: .9rem;
}
.vk.del:hover  { background: #ffe0e0; }
.vk.del.pressed,
.vk.del:active { box-shadow: 0 0 0 #e89090; }

/* ── TRANSITION CARDS (countdown / gameover / victory) ── */
.overlay-card {
  background: white;
  border-radius: var(--card-radius);
  box-shadow: 0 8px 0 rgba(0,0,0,.1), 0 14px 30px rgba(0,0,0,.08);
  padding: 48px 28px;
  text-align: center;
  display: none;
}
.overlay-card.show { display: block; animation: cardPop .42s cubic-bezier(.34,1.56,.64,1); }
@keyframes cardPop { from { transform: scale(.72); opacity: 0; } to { transform: scale(1); opacity: 1; } }

/* countdown */
.cd-num {
  font-family: 'Fredoka One', cursive;
  font-size: 5.8rem; line-height: 1; color: var(--blue-dark);
  animation: numPop .38s cubic-bezier(.34,1.56,.64,1);
}
@keyframes numPop { from { transform: scale(.25); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.cd-lbl { font-family: 'Fredoka One', cursive; font-size: 1.4rem; color: #6a8fa8; margin-top: 10px; }

/* game over */
.go-emoji { font-size: 3.4rem; display: block; margin-bottom: 4px; animation: cardPop .4s .2s both; }
.go-title { font-family: 'Fredoka One', cursive; font-size: 2.2rem; color: var(--coral-dark); margin-bottom: 8px; }
.go-sub   { color: #6a8fa8; font-weight: 700; font-size: .93rem; margin-bottom: 4px; }
.go-word  {
  font-family: 'Fredoka One', cursive; font-size: 2.5rem;
  color: var(--blue-dark); background: #f0f8ff;
  border-radius: 14px; padding: 8px 28px; margin: 12px 0;
  display: inline-block; letter-spacing: 3px;
}
.go-enc   { color: #3a8a54; font-weight: 800; font-size: .93rem; margin-bottom: 24px; }

/* victory */
.vic-trophies { font-size: 3.4rem; margin-bottom: 4px; animation: cardPop .4s .2s both; display: block; }
.vic-title { font-family: 'Fredoka One', cursive; font-size: 2.3rem; color: var(--blue-dark); margin-bottom: 8px; }
.vic-sub   { color: #6a8fa8; font-weight: 700; font-size: .93rem; margin-bottom: 24px; }

/* shared big buttons */
.big-btn {
  font-family: 'Fredoka One', cursive;
  font-size: 1.2rem; padding: 13px 38px;
  border: none; border-radius: 50px; cursor: pointer;
  transition: transform .08s, box-shadow .08s;
  display: inline-block;
}
.big-btn:active { transform: translateY(4px); }
.btn-blue   { background: var(--blue); color: white; box-shadow: 0 5px 0 var(--blue-dark); }
.btn-blue:active { box-shadow: 0 1px 0 var(--blue-dark); }
.btn-green  { background: var(--grass); color: white; box-shadow: 0 5px 0 var(--grass-dark); }
.btn-green:active { box-shadow: 0 1px 0 var(--grass-dark); }

/* confetti */
.cf-layer { position: fixed; inset: 0; pointer-events: none; z-index: 300; overflow: hidden; }
.cp { position: absolute; top: -18px; animation: cffall linear forwards; }
@keyframes cffall { to { transform: translateY(110vh) rotate(720deg); opacity: 0; } }

.hidden { display: none !important; }
</style>
</head>
<body>

<div class="cf-layer" id="cfLayer"></div>

<!-- ════ SCREEN 1: HOME ════ -->
<div class="screen" id="screen-home">
  <div class="home-card">
    <div class="home-hero">
      <span class="wiz">🧙‍♂️</span>
      <h1>Word Wizard</h1>
    </div>
    <div class="home-body">
      <span class="field-label">👤 Enter your name to play</span>
      <div class="name-row">
        <input class="name-input" type="text" id="nameInput" placeholder="Your name…" autocomplete="off" maxlength="20">
        <button class="play-btn" id="playBtn">Play! 🚀</button>
      </div>

      <p class="lb-head">🏆 Leaderboard</p>
      <table class="lb-table">
        <thead><tr><th>#</th><th>Player</th><th>⭐ Stars</th></tr></thead>
        <tbody id="lbBody">
          <tr><td colspan="3"><div class="lb-empty">No players yet — be the first! 🌟</div></td></tr>
        </tbody>
      </table>
      <div class="clear-link"><button id="clearBtn">🗑️ Clear</button></div>
    </div>
  </div>
</div>

<!-- ════ SCREEN 2: GAME ════ -->
<div class="screen hidden" id="screen-game">
  <div class="game-wrap">

    <!-- top bar -->
    <div class="topbar">
      <div class="topbar-player">🧙‍♂️ <span id="playerEl">—</span></div>
      <div class="topbar-score">⭐ <span id="scoreEl">0</span> stars</div>
      <button class="home-btn" id="homeBtn">← Home</button>
    </div>

    <!-- level pips + labels -->
    <div class="level-strip" id="pipStrip"></div>
    <div class="pip-labels" id="pipLabels"></div>

    <!-- timer -->
    <div class="timer-wrap hidden" id="timerWrap">
      <div class="timer-bar" id="timerBar" style="width:100%"></div>
      <span class="timer-secs" id="timerSecs">20</span>
    </div>

    <!-- word card -->
    <div class="word-card" id="wordCard">
      <div class="rainbow-bar"></div>
      <span class="level-badge l1" id="levelBadge">⭐ Level 1</span>
      <div class="dots" id="dotsEl"></div>
      <div class="scrambled" id="scrambledEl">—</div>
      <p class="hint">Unscramble the letters!</p>
      <input class="answer-input" type="text" id="answerInput"
        placeholder="type here" autocomplete="off" spellcheck="false" disabled>
      <button class="check-btn" id="checkBtn" disabled>Check ✓</button>
      <div class="status-msg" id="statusMsg"></div>
    </div>

    <!-- virtual keyboard -->
    <div class="vkb" id="vkb">
      <div class="vkb-row" id="vkr1"></div>
      <div class="vkb-row" id="vkr2"></div>
      <div class="vkb-row" id="vkr3"></div>
    </div>

    <!-- countdown -->
    <div class="overlay-card" id="cdCard">
      <div class="cd-num" id="cdNum">3</div>
      <div class="cd-lbl" id="cdLbl">Get ready!</div>
    </div>

    <!-- game over -->
    <div class="overlay-card" id="goCard">
      <span class="go-emoji">😢</span>
      <h2 class="go-title">Game Over!</h2>
      <p class="go-sub">The right word was…</p>
      <div class="go-word" id="goWord">—</div>
      <p class="go-enc">Keep practising — you'll get it! 💪</p>
      <button class="big-btn btn-blue" id="goHomeBtn">Back to Home 🏠</button>
    </div>

    <!-- victory -->
    <div class="overlay-card" id="victoryCard">
      <span class="vic-trophies">🎉🏆🎉</span>
      <h2 class="vic-title">You're a Word Wizard!</h2>
      <p class="vic-sub">All 5 levels completed perfectly! You're incredible! ⭐</p>
      <button class="big-btn btn-green" id="victoryBtn">Play Again! 🔄</button>
    </div>

  </div>
</div>

<script>
(function () {

// ─── WORD LISTS ───────────────────────────────────────────────
const LEVELS = {
  1: {
    label: 'Level 1', emoji: '⭐', cls: 'l1', timer: true,
    words: ["cat","dog","sun","run","big","map","fly","cup","hat","red",
            "bus","wet","top","sit","leg","win","fun","bed","sky","hen",
            "pen","tin","box","ant","jam","mud","net","wig","zip","dip"]
  },
  2: {
    label: 'Level 2', emoji: '🌟', cls: 'l2', timer: true,
    words: ["monday","tuesday","wednesday","thursday","friday","saturday","sunday",
            "play","road","rain","frog","jump","tree","soft","cold","warm",
            "milk","step","swim","flag","skip","spin","drum","clap","grab"]
  },
  3: {
    label: 'Level 3', emoji: '🍀', cls: 'l3', timer: false,
    words: ["january","february","march","april","may","june",
            "july","august","september","october","november","december",
            "stem","petal","petals","flower","stone","water","cloud","grass"]
  },
  4: {
    label: 'Level 4', emoji: '🔥', cls: 'l4', timer: false,
    words: ["because","recycle","reduce","reuse","waste","trash",
            "planet","energy","forest","garden","bottle","plastic",
            "nature","spring","summer","autumn","winter","silver"]
  },
  5: {
    label: 'Level 5', emoji: '💎', cls: 'l5', timer: false,
    words: ["beautiful","important","different","together","wonderful",
            "carefully","everyone","surprise","knowledge","discover",
            "treasure","question","mountain","chocolate","adventure",
            "favourite","creatures","butterfly","strawberry","thousand"]
  }
};

const SESSION = 8;
const TODAY   = new Date().toISOString().slice(0, 10);
const MEDALS  = ['🥇','🥈','🥉'];
const COLS    = ['#ffce47','#4ec76a','#3d8fe0','#f85555','#8b5cf6','#ff9f43','#48dbfb'];

let student = '', progressData = {}, todayStars = 0;
let gs = { level:1, words:[], index:0, currentWord:'', active:false, cdTimer:null, timerInterval:null, timeLeft:0 };

// DOM refs
const $ = id => document.getElementById(id);
const nameInput   = $('nameInput'),  playBtn    = $('playBtn'),
      lbBody      = $('lbBody'),     clearBtn   = $('clearBtn'),
      screenHome  = $('screen-home'),screenGame = $('screen-game'),
      playerEl    = $('playerEl'),   scoreEl    = $('scoreEl'),
      homeBtn     = $('homeBtn'),    pipStrip   = $('pipStrip'),
      pipLabels   = $('pipLabels'),  timerWrap  = $('timerWrap'),
      timerBar    = $('timerBar'),   timerSecs  = $('timerSecs'),
      wordCard    = $('wordCard'),   levelBadge = $('levelBadge'),
      dotsEl      = $('dotsEl'),     scrambledEl= $('scrambledEl'),
      answerInput = $('answerInput'),checkBtn   = $('checkBtn'),
      statusMsg   = $('statusMsg'),  cdCard     = $('cdCard'),
      cdNum       = $('cdNum'),      cdLbl      = $('cdLbl'),
      goCard      = $('goCard'),     goWord     = $('goWord'),
      goHomeBtn   = $('goHomeBtn'),  victoryCard= $('victoryCard'),
      victoryBtn  = $('victoryBtn'), cfLayer    = $('cfLayer');

// ─── VIRTUAL KEYBOARD (no ENTER key) ─────────────────────────
const KB_ROWS = [
  ['q','w','e','r','t','y','u','i','o','p'],
  ['a','s','d','f','g','h','j','k','l'],
  ['z','x','c','v','b','n','m','⌫']
];
KB_ROWS.forEach((row, ri) => {
  const rowEl = $('vkr' + (ri + 1));
  row.forEach(k => {
    const btn = document.createElement('button');
    btn.className = 'vk' + (k === '⌫' ? ' del' : '');
    btn.textContent = k === '⌫' ? '⌫ del' : k;
    btn.setAttribute('type', 'button');
    btn.addEventListener('pointerdown', e => {
      e.preventDefault();
      btn.classList.add('pressed');
      setTimeout(() => btn.classList.remove('pressed'), 130);
      if (k === '⌫') {
        answerInput.value = answerInput.value.slice(0, -1);
      } else {
        if (!answerInput.disabled) answerInput.value += k;
      }
    });
    rowEl.appendChild(btn);
  });
});

// ─── UTILS ───────────────────────────────────────────────────
function shuffle(w) {
  let a = w.split(''), s, t = 0;
  do {
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    s = a.join('');
  } while (s === w && ++t < 40);
  return s;
}

function pickWords(lv) {
  const pool = [...LEVELS[lv].words];
  for (let i = pool.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [pool[i], pool[j]] = [pool[j], pool[i]];
  }
  return pool.slice(0, Math.min(SESSION, pool.length));
}

function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

// ─── STORAGE ─────────────────────────────────────────────────
function loadData() {
  try { progressData = JSON.parse(localStorage.getItem('ww_v5') || '{}'); }
  catch (e) { progressData = {}; }
}
function saveData() {
  if (!student) return;
  const recs = progressData[student] || [];
  const i = recs.findIndex(r => r.date === TODAY);
  if (i >= 0) recs[i].stars = todayStars;
  else recs.push({ date: TODAY, stars: todayStars });
  progressData[student] = recs;
  try { localStorage.setItem('ww_v5', JSON.stringify(progressData)); } catch (e) {}
  scoreEl.textContent = todayStars;
  renderLB();
}
function totalStars(n) { return (progressData[n] || []).reduce((s, r) => s + (r.stars || 0), 0); }
function renderLB() {
  const names = Object.keys(progressData);
  if (!names.length) {
    lbBody.innerHTML = '<tr><td colspan="3"><div class="lb-empty">No players yet — be the first! 🌟</div></td></tr>';
    return;
  }
  const sorted = names.map(n => ({ name: n, stars: totalStars(n) })).sort((a, b) => b.stars - a.stars);
  lbBody.innerHTML = sorted.map((p, i) => `
    <tr class="${p.name === student ? 'me' : ''}">
      <td>${MEDALS[i] || (i + 1) + '.'}</td>
      <td>${p.name}${p.name === student ? ' 👈' : ''}</td>
      <td>⭐ ${p.stars}</td>
    </tr>`).join('');
}

// ─── SCREEN TRANSITIONS ──────────────────────────────────────
function showScreen(from, to) {
  from.classList.add('out-left');
  setTimeout(() => {
    from.classList.remove('out-left');
    from.classList.add('hidden');
    to.classList.remove('hidden');
    to.classList.add('out-right');
    requestAnimationFrame(() => {
      to.style.transition = 'opacity .38s, transform .38s';
      to.classList.remove('out-right');
    });
  }, 340);
}

// ─── PIPS ────────────────────────────────────────────────────
function buildPips() {
  pipStrip.innerHTML = '';
  pipLabels.innerHTML = '';
  for (let i = 1; i <= 5; i++) {
    const p = document.createElement('div');
    p.className = 'pip'; p.id = 'pip' + i;
    pipStrip.appendChild(p);

    const lb = document.createElement('div');
    lb.className = 'pip-lbl'; lb.id = 'piplbl' + i;
    lb.textContent = LEVELS[i].emoji + ' ' + LEVELS[i].label;
    pipLabels.appendChild(lb);
  }
}
function updatePips(lv) {
  for (let i = 1; i <= 5; i++) {
    const p = $('pip' + i), lb = $('piplbl' + i);
    p.className  = 'pip'     + (i < lv ? ' done' : i === lv ? ' active' : '');
    lb.className = 'pip-lbl' + (i < lv ? ' done' : i === lv ? ' active' : '');
  }
}

// ─── START GAME ──────────────────────────────────────────────
function startGame() {
  const raw = nameInput.value.trim();
  student = raw ? raw.toLowerCase() : 'wizard';
  nameInput.value = student;
  loadData();
  const rec = (progressData[student] || []).find(r => r.date === TODAY);
  todayStars = rec ? rec.stars : 0;
  playerEl.textContent = student;
  scoreEl.textContent  = todayStars;
  buildPips();
  hideAllCards();
  wordCard.style.display = '';
  showScreen(screenHome, screenGame);
  startLevel(1);
}

function goHome() {
  stopTimer();
  if (gs.cdTimer) { clearTimeout(gs.cdTimer); gs.cdTimer = null; }
  gs.active = false;
  showScreen(screenGame, screenHome);
  renderLB();
}

function hideAllCards() {
  wordCard.style.display = 'none';
  [cdCard, goCard, victoryCard].forEach(c => c.classList.remove('show'));
}

// ─── LEVEL MANAGEMENT ────────────────────────────────────────
function startLevel(lv) {
  gs.level = lv; gs.words = pickWords(lv); gs.index = 0; gs.active = true;
  const L = LEVELS[lv];
  levelBadge.className = 'level-badge ' + L.cls;
  levelBadge.textContent = L.emoji + ' ' + L.label;
  updatePips(lv);
  [cdCard, goCard, victoryCard].forEach(c => c.classList.remove('show'));
  wordCard.style.display = '';
  if (L.timer) timerWrap.classList.remove('hidden');
  else { timerWrap.classList.add('hidden'); stopTimer(); }
  showWord();
}

function showWord() {
  gs.currentWord = gs.words[gs.index];
  scrambledEl.textContent = shuffle(gs.currentWord);
  answerInput.value = '';
  answerInput.disabled = false;
  checkBtn.disabled = false;
  statusMsg.textContent = '';
  // dots
  dotsEl.innerHTML = '';
  gs.words.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i < gs.index ? ' done' : i === gs.index ? ' cur' : '');
    dotsEl.appendChild(d);
  });
  setTimeout(() => answerInput.focus(), 50);
  if (LEVELS[gs.level].timer) startTimer(20);
}

// ─── TIMER ───────────────────────────────────────────────────
function startTimer(secs) {
  stopTimer();
  gs.timeLeft = secs;
  timerBar.style.transition = 'none';
  timerBar.style.width = '100%';
  timerBar.className = 'timer-bar';
  timerSecs.textContent = secs;
  void timerBar.offsetHeight;
  timerBar.style.transition = 'width 1s linear';

  gs.timerInterval = setInterval(() => {
    gs.timeLeft--;
    const pct = (gs.timeLeft / secs) * 100;
    timerBar.style.width = pct + '%';
    timerSecs.textContent = gs.timeLeft;
    if      (pct <= 25) timerBar.className = 'timer-bar danger';
    else if (pct <= 55) timerBar.className = 'timer-bar warn';
    if (gs.timeLeft <= 0) { stopTimer(); triggerGameOver(); }
  }, 1000);
}
function stopTimer() {
  if (gs.timerInterval) { clearInterval(gs.timerInterval); gs.timerInterval = null; }
}

// ─── ANSWER LOGIC ────────────────────────────────────────────
function checkAnswer() {
  if (!gs.active) return;
  const ans = answerInput.value.trim().toLowerCase();
  if (!ans) { answerInput.focus(); return; }
  if (ans === gs.currentWord) handleCorrect();
  else triggerGameOver();
}

function handleCorrect() {
  stopTimer();
  todayStars++;
  saveData();
  answerInput.classList.add('glow');
  setTimeout(() => answerInput.classList.remove('glow'), 450);
  statusMsg.textContent = '✅ Correct!';
  answerInput.disabled = true;
  checkBtn.disabled = true;
  setTimeout(() => {
    statusMsg.textContent = '';
    gs.index++;
    if (gs.index >= gs.words.length) levelComplete();
    else showWord();
  }, 700);
}

function triggerGameOver() {
  stopTimer();
  gs.active = false;
  answerInput.classList.add('shake');
  setTimeout(() => answerInput.classList.remove('shake'), 400);
  answerInput.disabled = true;
  checkBtn.disabled = true;
  setTimeout(() => {
    wordCard.style.display = 'none';
    timerWrap.classList.add('hidden');
    goWord.textContent = gs.currentWord;
    goCard.classList.add('show');
  }, 500);
}

// ─── LEVEL COMPLETE ──────────────────────────────────────────
function levelComplete() {
  gs.active = false;
  wordCard.style.display = 'none';
  timerWrap.classList.add('hidden');
  const next = gs.level + 1;
  if (next <= 5) startCountdown(next);
  else { victoryCard.classList.add('show'); launchConfetti(160); }
}

function startCountdown(nextLv) {
  cdCard.classList.add('show');
  const steps = [
    { n: '🎉', l: 'Level Complete!' },
    { n: '3',  l: 'Get ready…'      },
    { n: '2',  l: 'Almost there…'   },
    { n: '1',  l: 'Here we go!'     },
    { n: '🚀', l: 'Go!'             }
  ];
  let i = 0;
  function tick() {
    cdNum.textContent = steps[i].n;
    cdLbl.textContent = steps[i].l;
    cdNum.style.animation = 'none'; void cdNum.offsetHeight; cdNum.style.animation = '';
    i++;
    if (i < steps.length) gs.cdTimer = setTimeout(tick, 750);
    else gs.cdTimer = setTimeout(() => { cdCard.classList.remove('show'); startLevel(nextLv); }, 600);
  }
  tick();
}

// ─── CONFETTI ────────────────────────────────────────────────
function launchConfetti(n) {
  for (let i = 0; i < n; i++) {
    const p = document.createElement('div');
    p.className = 'cp';
    p.style.left = (Math.random() * 100) + '%';
    const sz = (6 + Math.random() * 11) + 'px';
    p.style.width = p.style.height = sz;
    p.style.background = rand(COLS);
    p.style.borderRadius = Math.random() > .5 ? '50%' : '3px';
    p.style.animationDuration  = (1.2 + Math.random() * 1.7) + 's';
    p.style.animationDelay     = (Math.random() * .9) + 's';
    cfLayer.appendChild(p);
    setTimeout(() => p.remove(), 3500);
  }
}

// ─── EVENTS ──────────────────────────────────────────────────
playBtn.addEventListener('click', startGame);
nameInput.addEventListener('keypress', e => { if (e.key === 'Enter') startGame(); });
checkBtn.addEventListener('click', checkAnswer);
answerInput.addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); checkAnswer(); } });
answerInput.addEventListener('input', () => { answerInput.value = answerInput.value.toLowerCase(); });
homeBtn.addEventListener('click', goHome);
goHomeBtn.addEventListener('click', () => { goCard.classList.remove('show'); goHome(); });
victoryBtn.addEventListener('click', () => {
  victoryCard.classList.remove('show');
  buildPips(); hideAllCards();
  wordCard.style.display = '';
  startLevel(1);
});
clearBtn.addEventListener('click', () => {
  if (confirm('Clear ALL player data?')) {
    localStorage.removeItem('ww_v5');
    progressData = {}; todayStars = 0;
    renderLB();
  }
});

// ─── INIT ────────────────────────────────────────────────────
loadData();
renderLB();

})();
</script>
</body>
</html>
